<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_app">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/textBotTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/bf_text"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/textBotInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_card"
            android:lineSpacingExtra="5dp"
            android:padding="14dp"
            android:textColor="@color/bf_text_secondary"
            android:textSize="15sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/buttonStartBot"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_marginEnd="8dp"
                android:layout_weight="1"
                android:background="@drawable/bg_button_primary"
                android:text="Запустить"
                android:textAllCaps="false"
                android:textColor="@color/bf_text" />

            <Button
                android:id="@+id/buttonStopBot"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:background="@drawable/bg_button_secondary"
                android:text="Остановить"
                android:textAllCaps="false"
                android:textColor="@color/bf_text" />
        </LinearLayout>

        <Button
            android:id="@+id/buttonEditScript"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_button_secondary"
            android:text="Редактировать скрипт"
            android:textAllCaps="false"
            android:textColor="@color/bf_text" />

        <Button
            android:id="@+id/buttonBotLogs"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_button_secondary"
            android:text="Логи"
            android:textAllCaps="false"
            android:textColor="@color/bf_text" />

        <Button
            android:id="@+id/buttonResetOffset"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_button_secondary"
            android:text="Сбросить offset"
            android:textAllCaps="false"
            android:textColor="@color/bf_text" />

        <Button
            android:id="@+id/buttonDeleteBot"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="22dp"
            android:background="@drawable/bg_button_danger"
            android:text="Удалить"
            android:textAllCaps="false"
            android:textColor="@color/bf_text" />

    </LinearLayout>
</ScrollView>
