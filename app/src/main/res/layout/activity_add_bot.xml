<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_app"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Добавить бота"
            android:textColor="@color/bf_text"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Название"
            android:textColor="@color/bf_text_secondary"
            android:textSize="14sp" />

        <EditText
            android:id="@+id/inputBotName"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="6dp"
            android:background="@drawable/bg_edit_text"
            android:hint="Например: Test Echo Bot"
            android:singleLine="true"
            android:textColor="@color/bf_text"
            android:textColorHint="@color/bf_text_secondary" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="Telegram bot token"
            android:textColor="@color/bf_text_secondary"
            android:textSize="14sp" />

        <EditText
            android:id="@+id/inputToken"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="6dp"
            android:background="@drawable/bg_edit_text"
            android:hint="123456:ABC..."
            android:inputType="textNoSuggestions"
            android:singleLine="true"
            android:textColor="@color/bf_text"
            android:textColorHint="@color/bf_text_secondary" />

        <Button
            android:id="@+id/buttonCheckToken"
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_button_secondary"
            android:text="Проверить токен"
            android:textAllCaps="false"
            android:textColor="@color/bf_text" />

        <TextView
            android:id="@+id/textTokenResult"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textColor="@color/bf_text_secondary"
            android:textSize="14sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="Режим"
            android:textColor="@color/bf_text_secondary"
            android:textSize="14sp" />

        <RadioGroup
            android:id="@+id/radioMode"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:orientation="horizontal">

            <RadioButton
                android:id="@+id/radioTemplate"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:buttonTint="@color/bf_accent"
                android:checked="true"
                android:text="TEMPLATE"
                android:textColor="@color/bf_text" />

            <RadioButton
                android:id="@+id/radioDeveloper"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:buttonTint="@color/bf_accent"
                android:text="DEVELOPER"
                android:textColor="@color/bf_text" />
        </RadioGroup>

        <TextView
            android:id="@+id/textTemplateLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="Шаблон"
            android:textColor="@color/bf_text_secondary"
            android:textSize="14sp" />

        <Spinner
            android:id="@+id/spinnerTemplates"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="6dp"
            android:background="@drawable/bg_edit_text" />

        <Button
            android:id="@+id/buttonSaveBot"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="26dp"
            android:background="@drawable/bg_button_primary"
            android:text="Сохранить"
            android:textAllCaps="false"
            android:textColor="@color/bf_text" />

    </LinearLayout>
</ScrollView>
