<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_app">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Настройки"
            android:textColor="@color/bf_text"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_card"
            android:lineSpacingExtra="5dp"
            android:padding="14dp"
            android:text="BotForge хранит метаданные и скрипты локально в SharedPreferences, а Telegram-токены — отдельно в EncryptedSharedPreferences через Android Keystore. Зашифрованные токены исключены из Auto Backup и переноса между устройствами.\n\nПриложение не обещает 24/7-хостинг: Android может ограничивать сеть, фоновые потоки и батарею. Используйте BotForge как локальный раннер, учебную среду и инструмент тестирования."
            android:textColor="@color/bf_text_secondary"
            android:textSize="15sp" />

        <Button
            android:id="@+id/buttonScriptApiDocs"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_button_secondary"
            android:text="Документация Script API"
            android:textAllCaps="false"
            android:textColor="@color/bf_text" />

    </LinearLayout>
</ScrollView>
