<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:background="@drawable/bg_card"
    android:orientation="vertical"
    android:padding="14dp">

    <TextView
        android:id="@+id/textTemplateName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="@color/bf_text"
        android:textSize="19sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/textTemplateDescription"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:lineSpacingExtra="3dp"
        android:textColor="@color/bf_text_secondary"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/textTemplateDifficulty"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:background="@drawable/bg_chip"
        android:textColor="@color/bf_text"
        android:textSize="13sp" />

    <Button
        android:id="@+id/buttonUseTemplate"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:layout_marginTop="12dp"
        android:background="@drawable/bg_button_primary"
        android:text="Использовать"
        android:textAllCaps="false"
        android:textColor="@color/bf_text" />

</LinearLayout>
