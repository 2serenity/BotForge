<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_app"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:id="@+id/textEditorTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="@color/bf_text"
        android:textSize="24sp"
        android:textStyle="bold" />

    <EditText
        android:id="@+id/inputScript"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="14dp"
        android:layout_weight="1"
        android:background="@drawable/bg_edit_text"
        android:fontFamily="monospace"
        android:gravity="top|start"
        android:inputType="textMultiLine|textNoSuggestions"
        android:lineSpacingExtra="2dp"
        android:minLines="16"
        android:scrollbars="vertical"
        android:textColor="@color/bf_text"
        android:textColorHint="@color/bf_text_secondary"
        android:textSize="14sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:orientation="horizontal">

        <Button
            android:id="@+id/buttonSaveScript"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_marginEnd="8dp"
            android:layout_weight="1"
            android:background="@drawable/bg_button_primary"
            android:text="Сохранить"
            android:textAllCaps="false"
            android:textColor="@color/bf_text" />

        <Button
            android:id="@+id/buttonCheckScript"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:background="@drawable/bg_button_secondary"
            android:text="Проверить"
            android:textAllCaps="false"
            android:textColor="@color/bf_text" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:orientation="horizontal">

        <Button
            android:id="@+id/buttonEditorStart"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_marginEnd="8dp"
            android:layout_weight="1"
            android:background="@drawable/bg_button_primary"
            android:text="Запустить"
            android:textAllCaps="false"
            android:textColor="@color/bf_text" />

        <Button
            android:id="@+id/buttonEditorStop"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:background="@drawable/bg_button_secondary"
            android:text="Остановить"
            android:textAllCaps="false"
            android:textColor="@color/bf_text" />
    </LinearLayout>

    <Button
        android:id="@+id/buttonEditorLogs"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:layout_marginTop="10dp"
        android:background="@drawable/bg_button_secondary"
        android:text="Логи"
        android:textAllCaps="false"
        android:textColor="@color/bf_text" />

    <Button
        android:id="@+id/buttonEditorDocs"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:layout_marginTop="10dp"
        android:background="@drawable/bg_button_secondary"
        android:text="API скриптов"
        android:textAllCaps="false"
        android:textColor="@color/bf_text" />

    <Button
        android:id="@+id/buttonSaveAsTemplate"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:layout_marginTop="10dp"
        android:background="@drawable/bg_button_secondary"
        android:text="Сохранить как шаблон"
        android:textAllCaps="false"
        android:textColor="@color/bf_text" />

</LinearLayout>
